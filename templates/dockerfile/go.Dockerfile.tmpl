# Generated by rcloud. Assumes the main package is at the build-context root;
# change the build path (e.g. ./cmd/server) if yours differs.
FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /out/server .

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /out/server /server
EXPOSE [[ .Port ]]
ENTRYPOINT ["/server"]
