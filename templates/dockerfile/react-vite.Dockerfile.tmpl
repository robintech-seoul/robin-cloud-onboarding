# Generated by rcloud. Vite build (output: dist) served by nginx with SPA fallback.
FROM node:20-alpine AS builder
WORKDIR /app
[[- if eq .PackageManager "pnpm" ]]
RUN corepack enable
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile
COPY . .
RUN pnpm build
[[- else if eq .PackageManager "yarn" ]]
RUN corepack enable
COPY package.json yarn.lock* ./
RUN yarn install --frozen-lockfile
COPY . .
RUN yarn build
[[- else ]]
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build
[[- end ]]

FROM nginx:1.27-alpine
# SPA fallback so client-side routes don't 404.
RUN printf 'server {\n  listen [[ .Port ]];\n  root /usr/share/nginx/html;\n  location / { try_files $uri /index.html; }\n}\n' > /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE [[ .Port ]]
CMD ["nginx", "-g", "daemon off;"]
