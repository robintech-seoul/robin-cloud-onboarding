# Generated by rcloud. Next.js production server (next build → next start).
# For a smaller image, set `output: 'standalone'` in next.config and adapt this file.
FROM node:20-alpine
WORKDIR /app
[[- range .BuildArgs ]]
ARG [[ . ]]
ENV [[ . ]]=$[[ . ]]
[[- end ]]
[[- if eq .PackageManager "pnpm" ]]
RUN corepack enable
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile
COPY . .
RUN pnpm build
[[- else if eq .PackageManager "yarn" ]]
RUN corepack enable
COPY package.json yarn.lock* ./
RUN yarn install --frozen-lockfile
COPY . .
RUN yarn build
[[- else ]]
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build
[[- end ]]
ENV PORT=[[ .Port ]] \
    HOSTNAME=0.0.0.0 \
    NODE_ENV=production
EXPOSE [[ .Port ]]
[[- if eq .PackageManager "pnpm" ]]
CMD ["pnpm", "start"]
[[- else if eq .PackageManager "yarn" ]]
CMD ["yarn", "start"]
[[- else ]]
CMD ["npm", "run", "start"]
[[- end ]]
