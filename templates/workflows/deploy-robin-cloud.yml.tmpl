# Generated by robin-cloud-onboarding — do not edit by hand.
# Re-generate after changing rules/ or robin-deploy.yaml.
#
# Flow: build each changed component → push to <project>-<module> in Robin-Cloud's
# ECR (GitHub OIDC, no static keys) → ask the Robin-Cloud deploy API to bump the tag.
#
# Engine placeholders use doubled-square-bracket delimiters so GitHub's own
# ${{ ... }} expressions pass through literally. This file is the canonical OUTPUT SHAPE.
name: Deploy to Robin-Cloud

on:
  push:
    branches:
      - [[ .DefaultBranch ]]
  workflow_dispatch: {}            # manual "Run workflow" — builds all components (first build)

permissions:
  id-token: write                  # GitHub OIDC → assume the AWS role (no static keys)
  contents: read

env:
  AWS_REGION: [[ .Region ]]
  ECR_REGISTRY: ${{ secrets.AWS_ACCOUNT_ID }}.dkr.ecr.[[ .Region ]].amazonaws.com
  DEPLOY_API: [[ .ConsoleBaseURL ]]/api/v1/projects/[[ .Project ]]/deployments

jobs:
  # 1. Which components changed? (path filter per component)
  changes:
    runs-on: ubuntu-latest
    outputs:
      [[- range .Components ]]
      [[ .Module ]]: ${{ steps.filter.outputs.[[ .Module ]] }}
      [[- end ]]
    steps:
      - uses: actions/checkout@v4
      - uses: dorny/paths-filter@v3
        id: filter
        with:
          filters: |
            [[- range .Components ]]
            [[ .Module ]]:
              - '[[ .FilterGlob ]]'
            [[- end ]]

  # 2. Build + push each changed component to its ECR repo (OIDC auth, matrix).
  build-and-push:
    needs: changes
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        include:
          [[- range .Components ]]
          - module: [[ .Module ]]
            context: [[ .Context ]]
            changed: ${{ needs.changes.outputs.[[ .Module ]] }}
          [[- end ]]
    if: ${{ github.event_name == 'workflow_dispatch' || [[ .AnyChangedExpr ]] }}
    steps:
      - uses: actions/checkout@v4

      - name: Skip if unchanged (push only)
        if: github.event_name == 'push' && matrix.changed != 'true'
        run: echo "no changes in ${{ matrix.module }}; skipping" && exit 0

      - name: Configure AWS credentials (OIDC)
        if: github.event_name == 'workflow_dispatch' || matrix.changed == 'true'
        uses: aws-actions/configure-aws-credentials@v4
        with:
          role-to-assume: arn:aws:iam::${{ secrets.AWS_ACCOUNT_ID }}:role/[[ .OIDCRole ]]
          aws-region: ${{ env.AWS_REGION }}

      - name: Login to Amazon ECR
        if: github.event_name == 'workflow_dispatch' || matrix.changed == 'true'
        uses: aws-actions/amazon-ecr-login@v2

      - name: Set up Docker Buildx
        if: github.event_name == 'workflow_dispatch' || matrix.changed == 'true'
        uses: docker/setup-buildx-action@v3

      - name: Build and push
        if: github.event_name == 'workflow_dispatch' || matrix.changed == 'true'
        uses: docker/build-push-action@v6
        with:
          context: ${{ matrix.context }}
          push: true
          tags: |
            ${{ env.ECR_REGISTRY }}/[[ .Project ]]-${{ matrix.module }}:${{ github.sha }}
            ${{ env.ECR_REGISTRY }}/[[ .Project ]]-${{ matrix.module }}:latest
          cache-from: type=gha
          cache-to: type=gha,mode=max

  # 3. Ask Robin-Cloud to deploy the new image tag for each changed component.
  #    Tolerant of 404 (project not yet deploy-config'd in the console): the image is
  #    already in ECR, so just warn and let the first console deploy-config pick it up.
  deploy:
    needs: [changes, build-and-push]
    if: always() && needs.build-and-push.result == 'success'
    runs-on: ubuntu-latest
    steps:
      - name: Request deployment for changed components
        env:
          DEPLOY_TOKEN: ${{ secrets.ROBIN_DEPLOY_TOKEN }}
          TAG: ${{ github.sha }}
          IS_DISPATCH: ${{ github.event_name == 'workflow_dispatch' }}
          [[- range .Components ]]
          CHANGED_[[ .ModuleEnv ]]: ${{ needs.changes.outputs.[[ .Module ]] }}
          [[- end ]]
        run: |
          deploy() {   # deploy <component> <tag>
            echo "deploying $1 -> $2"
            code=$(curl -sS -o /tmp/resp -w '%{http_code}' -X POST "$DEPLOY_API" \
              -H "Authorization: Bearer ${DEPLOY_TOKEN}" \
              -H "Content-Type: application/json" \
              -d "{\"component\":\"$1\",\"tag\":\"$2\"}") || true
            cat /tmp/resp 2>/dev/null; echo
            if [ "$code" = "404" ]; then
              echo "::warning::$1: project not onboarded yet (run deploy-config in the console). Image is in ECR; skipping bump."
            elif [ "$code" -ge 300 ] 2>/dev/null; then
              echo "::error::$1: deploy request failed (HTTP $code)"; exit 1
            fi
          }
          [[- range .Components ]]
          if [ "$CHANGED_[[ .ModuleEnv ]]" = "true" ] || [ "$IS_DISPATCH" = "true" ]; then deploy [[ .Module ]] "$TAG"; fi
          [[- end ]]
          exit 0
