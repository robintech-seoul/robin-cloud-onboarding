# Generated by robin-cloud-onboarding — do not edit by hand.
# Re-generate after changing rules/ or robin-deploy.yaml.
#
# Thin caller of the Robin-Cloud deploy composite action: per changed component it
# builds + pushes to <project>-<module> in ECR (GitHub OIDC) and requests a deploy.
# The deploy logic lives in the versioned action, so it updates centrally.
#
# Engine placeholders use doubled-square-bracket delimiters so GitHub's own
# ${{ ... }} expressions pass through literally. This file is the canonical OUTPUT SHAPE.
name: Deploy to Robin-Cloud

on:
  push:
    branches:
      - [[ .DefaultBranch ]]
  workflow_dispatch: {}            # manual "Run workflow" — builds all components (first build)

permissions:
  id-token: write                  # GitHub OIDC → assume the AWS role (no static keys)
  contents: read

jobs:
  # 1. Which components changed? (path filter per component)
  changes:
    runs-on: ubuntu-latest
    outputs:
      [[- range .Components ]]
      [[ .Module ]]: ${{ steps.filter.outputs.[[ .Module ]] }}
      [[- end ]]
    steps:
      - uses: actions/checkout@v4
      - uses: dorny/paths-filter@v3
        id: filter
        with:
          filters: |
            [[- range .Components ]]
            [[ .Module ]]:
              - '[[ .FilterGlob ]]'
            [[- end ]]

  # 2. Build + push + deploy each changed component via the Robin-Cloud action.
  deploy:
    needs: changes
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        include:
          [[- range .Components ]]
          - module: [[ .Module ]]
            context: [[ .Context ]]
            changed: ${{ needs.changes.outputs.[[ .Module ]] }}
          [[- end ]]
    if: ${{ github.event_name == 'workflow_dispatch' || [[ .AnyChangedExpr ]] }}
    steps:
      - uses: actions/checkout@v4

      - name: Skip if unchanged (push only)
        if: github.event_name == 'push' && matrix.changed != 'true'
        run: echo "no changes in ${{ matrix.module }}; skipping" && exit 0

      - name: Build, push, and deploy
        if: github.event_name == 'workflow_dispatch' || matrix.changed == 'true'
        uses: [[ .ActionRef ]]
        with:
          project: [[ .Project ]]
          module: ${{ matrix.module }}
          context: ${{ matrix.context }}
          tag: ${{ github.sha }}
          # Account ID and role are NOT hardcoded — sourced from this repo's secrets.
          aws-account-id: ${{ secrets.AWS_ACCOUNT_ID }}
          oidc-role: ${{ secrets.ROBIN_OIDC_ROLE }}
          deploy-token: ${{ secrets.ROBIN_DEPLOY_TOKEN }}
          region: [[ .Region ]]
          console-url: [[ .ConsoleBaseURL ]]
